# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=tikinti
POSTGRES_PASSWORD=your_db_password_here
POSTGRES_DB=tikinti_db

# Full connection string for running the server locally (outside Docker).
# In Docker, docker-compose builds its own using Host=db (internal service name).
CONNECTION_STRING=Host=localhost;Port=5432;Database=tikinti_db;Username=tikinti;Password=your_db_password_here

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong random string (min 32 chars)
# Example: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_min_32_characters_long!
JWT_ISSUER=tikinti-api
JWT_AUDIENCE=tikinti-admin
JWT_EXPIRY_HOURS=24

# ── Application ──────────────────────────────────────────────────────────────
COMPANY_NAME=Your Company Name

# ── CORS — comma-separated list of allowed frontend origins ───────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Initial admin credentials ─────────────────────────────────────────────────
# Used only when the database is empty on first startup.
# Change these before deploying!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here
